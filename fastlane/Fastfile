# Shio — fastlane.
#
#   iOS → TestFlight (App Store Connect).
#   Mac → Developer ID + notarization (DIRECT download, a DMG off shio.sh).
#         The Mac App Store can't host a real terminal: it mandates the App
#         Sandbox, which forbids running arbitrary shells + reading your files.
#
# AUTH — App Store Connect API key (Users & Access → Integrations → App Store
# Connect API → generate a key with App Manager access). Put these in
# fastlane/.env (gitignored), or export them:
#   ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_PATH  (path to the downloaded .p8)
#
# FIRST TIME: `fastlane ios setup` creates the iOS app record in ASC.

opt_out_usage

# Regenerate the Xcode project (xcodegen) and make sure the gitignored
# GhosttyKit libs are present before any build.
before_all do
  Dir.chdir("..") do
    sh("xcodegen")
    if Dir.glob("Frameworks/GhosttyKit.xcframework/**/*.a").empty?
      sh("./scripts/refresh-ghostty.sh --fetch")
    end
  end
end

def asc_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: File.expand_path(ENV.fetch("ASC_KEY_PATH"))
  )
end

# App Store build numbers must strictly increase — a UTC timestamp guarantees it
# without a counter to maintain (xcodegen would clobber an incremented pbxproj).
def build_number
  Time.now.utc.strftime("%Y%m%d%H%M")
end

# xcodebuild flags that let the ARCHIVE step provision via the ASC API key
# instead of a signed-in Xcode account. gym auto-passes these to the *export*
# step but not the archive — so on a CI runner (no Xcode account) automatic
# signing fails with "No Accounts" unless we pass them here. Harmless locally
# (the key just supplements your account). Empty if the env isn't set.
def xcode_asc_auth
  return "" unless ENV["ASC_KEY_ID"] && ENV["ASC_ISSUER_ID"] && ENV["ASC_KEY_PATH"]
  " -allowProvisioningUpdates" \
  " -authenticationKeyID #{ENV['ASC_KEY_ID']}" \
  " -authenticationKeyIssuerID #{ENV['ASC_ISSUER_ID']}" \
  " -authenticationKeyPath #{File.expand_path(ENV['ASC_KEY_PATH'])}"
end

platform :ios do
  desc "One-time: create the iOS app record in App Store Connect"
  lane :setup do
    asc_key   # sets the API key in the lane context; produce reads it from there
    produce(
      app_identifier: "sh.shio.app",
      app_name: "Shio",
      language: "en-US",
      sku: "shio-ios-001"
    )
  end

  desc "Build the iPhone/iPad app and upload to TestFlight"
  lane :beta do
    key = asc_key
    build_app(
      project: "Shio.xcodeproj",
      scheme: "Shio",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build/ios",
      clean: true,
      # Automatic signing for BOTH archive and export. With the ASC API key in
      # context, gym passes -allowProvisioningUpdates to the export step, so
      # xcodebuild mints the Apple Distribution cert + App Store profiles for the
      # app and its extensions on demand — no manual profile mapping to maintain.
      export_options: { signingStyle: "automatic" },
      xcargs: "CURRENT_PROJECT_VERSION=#{build_number}#{xcode_asc_auth}"
    )
    upload_to_testflight(
      api_key: key,
      app_identifier: "sh.shio.app",
      skip_waiting_for_build_processing: true,
      changelog: "Shio beta — a real terminal for the agent era."
    )
  end
end

platform :mac do
  desc "Build, Developer-ID-sign, and notarize the Mac app → build/mac (DIRECT download, not the App Store)"
  lane :release do
    key = asc_key
    # Hardened Runtime is REQUIRED for notarization. ⚠️ It can also disable the
    # ObjC fork-safety opt-out the local terminal relies on — TEST the terminal
    # in this build before shipping (see DISTRIBUTION.md).
    build_mac_app(
      project: "Shio.xcodeproj",
      scheme: "ShioMac",
      configuration: "Release",
      export_method: "developer-id",
      output_directory: "build/mac",
      clean: true,
      # ShioMac uses iCloud/CloudKit + push + app groups, so even a Developer ID
      # build needs a provisioning profile. The ARCHIVE provisions automatically
      # via the API key (xcode_asc_auth). The EXPORT signs MANUALLY with the
      # local Developer ID cert + the pinned "Mac Team Direct" profile — automatic
      # export tries cloud-managed Developer ID signing, which the API key isn't
      # permitted to do ("Cloud signing permission error"). The profile is in the
      # keychain locally and installed from a secret in CI (valid through 2044).
      export_options: {
        signingStyle: "manual",
        signingCertificate: "Developer ID Application",
        provisioningProfiles: {
          "sh.shio.app.mac" => "Mac Team Direct Provisioning Profile: sh.shio.app.mac"
        }
      },
      xcargs: "CURRENT_PROJECT_VERSION=#{build_number} ENABLE_HARDENED_RUNTIME=YES#{xcode_asc_auth}"
    )
    notarize(
      package: "build/mac/Shio.app",
      api_key: key,
      bundle_id: "sh.shio.app.mac"
    )
  end
end
